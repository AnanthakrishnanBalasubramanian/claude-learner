rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Articles — anyone can read, only server can write
    match /articles/{articleId} {
      allow read: if true;
      allow write: if false;
    }

    // Daily briefs — anyone can read, only server can write
    match /dailyBriefs/{date} {
      allow read: if true;
      allow write: if false;
    }

    // User progress — single-user app, no auth
    match /userProgress/{userId} {
      allow read, write: if true;
    }

    // Bookmarks — single-user app, no auth
    match /bookmarks/{userId} {
      allow read, write: if true;
    }
  }
}
